# llm openai-compatible / github models
AI_PROVIDER=openai
AI_ENDPOINT=https://models.github.ai/inference
AI_MODEL=openai/gpt-4o-mini
AI_API_KEY=your_api_key

# pinecone rag
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=mental-health
PINECONE_GENERAL_INDEX=medical-chatbot

# crewai
CREWAI_TRACING_ENABLED=false
OTEL_SDK_DISABLED=true

# frontend
FRONTEND_URL=http://localhost:3000

# smtp brevo
AUTH_RESET_TOKEN_MINUTES=30
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_user
BREVO_SMTP_KEY=your_brevo_key
BREVO_FROM_EMAIL=your_email@example.com
BREVO_FROM_NAME=Multi-Agents Santé

# environment
APP_ENV=development